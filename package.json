    "monaco-themes": "^0.4.8",
    "ora": "^9.3.0",
    "playwright": "^1.59.1"
  },
  "description": "Script code, render cinema, grab your popcorn.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "peggy": "^5.1.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.4"
  },
  "homepage": "https://github.com/it-gorillaz/popcorn#readme",
  "keywords": [
    "cli",
    "code",
    "animation",
    "video",
    "screencast",
    "code-animation",
    "code-video",
    "code-renderer",
    "syntax-highlighting",
    "monaco-editor",
    "ffmpeg",
    "playwright",
    "developer-tools",
    "terminal",
    "scene",
    "scripting"
  ],
  "license": "MIT",
  "name": "@itgorillaz/popcorn",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/it-gorillaz/popcorn.git"
  },
  "scripts": {
    "build:parser": "peggy --format es src/parser/grammar.pegjs -o src/parser/parser.js",
    "build:vendor": "node scripts/build-vendor.js",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepare": "npm run build:parser && npm run build:vendor",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module",
  "version": "0.0.1"
}
